+
+package tech.pegasys.teku.statetransition.forkchoice.fcr;
+
+import tech.pegasys.teku.infrastructure.unsigned.UInt64;
+
+import org.apache.tuweni.bytes.Bytes32;
+
+import java.io.IOException;
+import java.net.URI;
+import java.net.URLEncoder;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.charset.StandardCharsets;
+import java.time.Duration;
+import java.util.Optional;
+
+import org.apache.tuweni.bytes.Bytes;
+
+public class HttpClient {
+  private final URI baseUri;
+  private final java.net.http.HttpClient client;
+
+  public HttpClient(final String beaconNodeUrl) {
+    this.baseUri = URI.create(stripTrailingSlash(beaconNodeUrl));
+    this.client =
+        java.net.http.HttpClient.newBuilder().connectTimeout(Duration.ofSeconds(30)).build();
+  }
+
+  public Bytes getState(final UInt64 slot) throws IOException, InterruptedException {
+    return getBytes("/eth/v2/debug/beacon/states/" + slot, false).orElseThrow();
+  }
+
+  public Optional<Bytes> getBlock(final UInt64 slot) throws IOException, InterruptedException {
+    return getBytes("/eth/v2/beacon/blocks/" + slot, true);
+  }
+
+  public Optional<Bytes> getBlockByRoot(final Bytes32 root)
+      throws IOException, InterruptedException {
+    return getBytes("/eth/v2/beacon/blocks/" + root.toHexString(), true);
+  }
+
+  public Bytes getBlockRequired(final UInt64 slot) throws IOException, InterruptedException {
+    return getBlock(slot)
+        .orElseThrow(() -> new IOException("missing required block at slot " + slot));
+  }
+
+  public byte[] getJson(final String path) throws IOException, InterruptedException {
+    final HttpRequest request =
+        HttpRequest.newBuilder(resolve(path))
+            .timeout(Duration.ofMinutes(2))
+            .header("Accept", "application/json")
+            .GET()
+            .build();
+    final HttpResponse<byte[]> response =
+        client.send(request, HttpResponse.BodyHandlers.ofByteArray());
+    if (response.statusCode() != 200) {
+      throw new IOException("GET " + path + " failed with HTTP " + response.statusCode());
+    }
+    return response.body();
+  }
+
+  static String queryParam(final UInt64 value) {
+    return URLEncoder.encode(value.toString(), StandardCharsets.UTF_8);
+  }
+
+  private Optional<Bytes> getBytes(final String path, final boolean notFoundIsEmpty)
+      throws IOException, InterruptedException {
+    final HttpRequest request =
+        HttpRequest.newBuilder(resolve(path))
+            .timeout(Duration.ofMinutes(2))
+            .header("Accept", "application/octet-stream")
+            .GET()
+            .build();
+    final HttpResponse<byte[]> response =
+        client.send(request, HttpResponse.BodyHandlers.ofByteArray());
+    if (response.statusCode() == 404 && notFoundIsEmpty) {
+      return Optional.empty();
+    }
+    if (response.statusCode() != 200) {
+      throw new IOException("GET " + path + " failed with HTTP " + response.statusCode());
+    }
+    return Optional.of(Bytes.wrap(response.body()));
+  }
+
+  private URI resolve(final String path) {
+    return baseUri.resolve(path.startsWith("/") ? path : "/" + path);
+  }
+
+  private static String stripTrailingSlash(final String value) {
+    if (value.endsWith("/")) {
+      return value.substring(0, value.length() - 1);
+    }
+    return value;
+  }
+}
