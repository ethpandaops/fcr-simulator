+package tech.pegasys.teku.statetransition.forkchoice.fcr;
+
+import tech.pegasys.teku.infrastructure.unsigned.UInt64;
+
+import java.io.IOException;
+import java.util.HashMap;
+import java.util.Map;
+import java.util.Optional;
+
+import com.fasterxml.jackson.databind.JsonNode;
+import com.fasterxml.jackson.databind.ObjectMapper;
+
+public class PlanFetcher {
+  private static final ObjectMapper OBJECT_MAPPER = new ObjectMapper();
+
+  private final HttpClient httpClient;
+
+  public PlanFetcher(final HttpClient httpClient) {
+    this.httpClient = httpClient;
+  }
+
+  public Map<UInt64, Optional<UInt64>> fetch(final UInt64 from, final UInt64 to)
+      throws IOException, InterruptedException {
+    final String path =
+        "/fcr-sim/v1/plan?from="
+            + HttpClient.queryParam(from)
+            + "&to="
+            + HttpClient.queryParam(to);
+    final JsonNode root = OBJECT_MAPPER.readTree(httpClient.getJson(path));
+    final Map<UInt64, Optional<UInt64>> plan = new HashMap<>();
+    for (JsonNode entry : root.required("entries")) {
+      final UInt64 simSlot = UInt64.valueOf(entry.required("sim_slot").asLong());
+      final JsonNode source = entry.get("source_block_slot");
+      plan.put(
+          simSlot,
+          source == null || source.isNull()
+              ? Optional.empty()
+              : Optional.of(UInt64.valueOf(source.asLong())));
+    }
+    return plan;
+  }
+}
