+    @JsonProperty("strict_one_slot_confirmed") boolean strictOneSlotConfirmed,
+    @JsonProperty("finalized_epoch") long finalizedEpoch,
+    @JsonProperty("justified_epoch") long justifiedEpoch,
+    @JsonProperty("source_block_slot") Long sourceBlockSlot,
+    @JsonProperty("num_attestations_injected") int numAttestationsInjected,
+    @JsonProperty("is_epoch_boundary") boolean isEpochBoundary,
+    @JsonProperty("is_missed_slot") boolean isMissedSlot,
+    @JsonProperty("fcr_eval_duration_us") long fcrEvalDurationUs) {}
