+
+package tech.pegasys.teku.statetransition.forkchoice.fcr;
+
+import java.nio.file.Path;
+import java.util.HashMap;
+import java.util.Map;
+
+public record Config(
+    String beaconNodeUrl,
+    long startSlot,
+    long endSlot,
+    long warmupStartSlot,
+    String network,
+    long byzantineThreshold,
+    String attestationSourceMode,
+    long lookaheadCap,
+    Path output) {
+
+  static Config parse(final String[] args) {
+    final Map<String, String> values = new HashMap<>();
+    for (int i = 0; i < args.length; i++) {
+      final String arg = args[i];
+      if (!arg.startsWith("--")) {
+        throw new IllegalArgumentException("unexpected positional argument: " + arg);
+      }
+      if (arg.equals("--manifest-json")) {
+        continue;
+      }
+      if (i + 1 >= args.length || args[i + 1].startsWith("--")) {
+        throw new IllegalArgumentException("missing value for " + arg);
+      }
+      values.put(arg.substring(2), args[++i]);
+    }
+
+    final Config cfg =
+        new Config(
+            required(values, "beacon-node-url"),
+            parseLong(required(values, "start-slot"), "start-slot"),
+            parseLong(required(values, "end-slot"), "end-slot"),
+            parseLong(required(values, "warmup-start-slot"), "warmup-start-slot"),
+            required(values, "network"),
+            parseLong(values.getOrDefault("byzantine-threshold", "25"), "byzantine-threshold"),
+            required(values, "attestation-source-mode"),
+            parseLong(required(values, "lookahead-cap"), "lookahead-cap"),
+            Path.of(required(values, "output")));
+    cfg.validate();
+    return cfg;
+  }
+
+  private void validate() {
+    if (!network.equals("mainnet")) {
+      throw new IllegalArgumentException("--network=" + network + " is not supported");
+    }
+    if (!attestationSourceMode.equals("next-non-missed")
+        && !attestationSourceMode.equals("strict-source-block-k-minus-1")) {
+      throw new IllegalArgumentException(
+          "--attestation-source-mode=" + attestationSourceMode + " is not supported");
+    }
+    if (warmupStartSlot > startSlot) {
+      throw new IllegalArgumentException("--warmup-start-slot must be <= --start-slot");
+    }
+    if (startSlot >= endSlot) {
+      throw new IllegalArgumentException("--start-slot must be < --end-slot");
+    }
+  }
+
+  private static String required(final Map<String, String> values, final String key) {
+    final String value = values.get(key);
+    if (value == null || value.isBlank()) {
+      throw new IllegalArgumentException("--" + key + " is required");
+    }
+    return value;
+  }
+
+  private static long parseLong(final String value, final String key) {
+    try {
+      return Long.parseUnsignedLong(value);
+    } catch (final NumberFormatException e) {
+      throw new IllegalArgumentException("--" + key + " must be an unsigned integer", e);
+    }
+  }
+}
