+package tech.pegasys.teku.statetransition.forkchoice.fcr;
+
+import static tech.pegasys.teku.infrastructure.time.TimeUtilities.secondsToMillis;
+import static tech.pegasys.teku.networks.Eth2NetworkConfiguration.DEFAULT_FORK_CHOICE_LATE_BLOCK_REORG_ENABLED;
+
+import com.google.common.io.MoreFiles;
+import com.google.common.io.RecursiveDeleteOption;
+
+import tech.pegasys.teku.bls.BLSConstants;
+import tech.pegasys.teku.bls.BLSSignatureVerifier;
+import tech.pegasys.teku.infrastructure.async.SafeFuture;
+import tech.pegasys.teku.infrastructure.async.eventthread.InlineEventThread;
+import tech.pegasys.teku.infrastructure.metrics.StubMetricsSystem;
+import tech.pegasys.teku.infrastructure.unsigned.UInt64;
+import tech.pegasys.teku.kzg.KZG;
+import tech.pegasys.teku.spec.Spec;
+import tech.pegasys.teku.spec.SpecFactory;
+import tech.pegasys.teku.spec.datastructures.attestation.ValidatableAttestation;
+import tech.pegasys.teku.spec.datastructures.blocks.BeaconBlockHeader;
+import tech.pegasys.teku.spec.datastructures.blocks.SignedBeaconBlock;
+import tech.pegasys.teku.spec.datastructures.blocks.SignedBlockAndState;
+import tech.pegasys.teku.spec.datastructures.execution.ExecutionPayloadContext;
+import tech.pegasys.teku.spec.datastructures.operations.Attestation;
+import tech.pegasys.teku.spec.datastructures.operations.IndexedAttestation;
+import tech.pegasys.teku.spec.datastructures.state.AnchorPoint;
+import tech.pegasys.teku.spec.datastructures.state.beaconstate.BeaconState;
+import tech.pegasys.teku.spec.executionlayer.ExecutionLayerChannelStub;
+import tech.pegasys.teku.spec.executionlayer.ForkChoiceState;
+import tech.pegasys.teku.spec.executionlayer.ForkChoiceUpdatedResult;
+import tech.pegasys.teku.spec.executionlayer.PayloadStatus;
+import tech.pegasys.teku.spec.logic.common.statetransition.availability.AvailabilityCheckerFactory;
+import tech.pegasys.teku.spec.logic.common.statetransition.results.BlockImportResult;
+import tech.pegasys.teku.spec.logic.common.util.AsyncBLSSignatureVerifier;
+import tech.pegasys.teku.statetransition.forkchoice.FcrForkChoiceAccess;
+import tech.pegasys.teku.statetransition.forkchoice.ForkChoice;
+import tech.pegasys.teku.statetransition.forkchoice.ForkChoiceNotifier;
+import tech.pegasys.teku.statetransition.forkchoice.ForkChoiceStateProvider;
+import tech.pegasys.teku.statetransition.forkchoice.ForkChoiceUpdatedResultSubscriber;
+import tech.pegasys.teku.statetransition.forkchoice.MergeTransitionBlockValidator;
+import tech.pegasys.teku.statetransition.forkchoice.PayloadValidationResult;
+import tech.pegasys.teku.statetransition.forkchoice.TickProcessor;
+import tech.pegasys.teku.statetransition.util.DebugDataDumper;
+import tech.pegasys.teku.statetransition.validation.BlockBroadcastValidator;
+import tech.pegasys.teku.storage.client.RecentChainData;
+import tech.pegasys.teku.storage.server.StateStorageMode;
+import tech.pegasys.teku.storage.storageSystem.FileBackedStorageSystemBuilder;
+import tech.pegasys.teku.storage.storageSystem.StorageSystem;
+
+import java.io.IOException;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+import java.util.Optional;
+import java.util.concurrent.CopyOnWriteArrayList;
+
+import org.apache.tuweni.bytes.Bytes32;
+
+public class Engine implements AutoCloseable {
+  private final Config cfg;
+  private final Spec spec;
+  private final HttpClient httpClient;
+  private final Path dataDir;
+  private final StorageSystem storageSystem;
+  private final RecentChainData recentChainData;
+  private final ForkChoice forkChoice;
+  private final ExecutionLayerChannelStub executionLayer;
+  private final Map<UInt64, Optional<UInt64>> plan;
+  private final OutputWriter outputWriter;
+
+  private Engine(
+      final Config cfg,
+      final Spec spec,
+      final HttpClient httpClient,
+      final Path dataDir,
+      final StorageSystem storageSystem,
+      final ForkChoice forkChoice,
+      final ExecutionLayerChannelStub executionLayer,
+      final Map<UInt64, Optional<UInt64>> plan,
+      final OutputWriter outputWriter) {
+    this.cfg = cfg;
+    this.spec = spec;
+    this.httpClient = httpClient;
+    this.dataDir = dataDir;
+    this.storageSystem = storageSystem;
+    this.recentChainData = storageSystem.recentChainData();
+    this.forkChoice = forkChoice;
+    this.executionLayer = executionLayer;
+    this.plan = plan;
+    this.outputWriter = outputWriter;
+  }
+
+  public static Engine bootstrap(final Config cfg) throws IOException, InterruptedException {
+    BLSConstants.disableBLSVerification();
+    final Spec spec =
+        SpecFactory.create(
+            cfg.network(),
+            false,
+            builder ->
+                builder
+                    .confirmationByzantineThreshold((int) cfg.byzantineThreshold())
+                    .committeeWeightEstimationAdjustmentFactor(5)
+                    .confirmationSlashingThreshold(25));
+    spec.reinitializeForTesting(
+        AvailabilityCheckerFactory.NOOP_BLOB_SIDECAR,
+        AvailabilityCheckerFactory.NOOP_DATACOLUMN_SIDECAR,
+        KZG.DISABLED);
+
+    final HttpClient httpClient = new HttpClient(cfg.beaconNodeUrl());
+    final UInt64 warmupStartSlot = UInt64.valueOf(cfg.warmupStartSlot());
+    final BeaconState anchorState =
+        spec.deserializeBeaconState(httpClient.getState(warmupStartSlot));
+    final Bytes32 anchorBlockRoot = BeaconBlockHeader.fromState(anchorState).getRoot();
+    final SignedBeaconBlock anchorBlock =
+        spec.deserializeSignedBeaconBlock(
+            httpClient
+                .getBlockByRoot(anchorBlockRoot)
+                .orElseThrow(
+                    () -> new IOException("missing anchor block root " + anchorBlockRoot)));
+
+    final Path dataDir = Files.createTempDirectory("fcr-teku");
+    final StorageSystem storageSystem =
+        FileBackedStorageSystemBuilder.create()
+            .storageMode(StateStorageMode.PRUNE)
+            .specProvider(spec)
+            .dataDir(dataDir)
+            .build();
+    final RecentChainData recentChainData = storageSystem.recentChainData();
+    final ExecutionLayerChannelStub executionLayer = new ExecutionLayerChannelStub(spec, false);
+    final InlineEventThread eventThread = new InlineEventThread();
+    final ForkChoiceNotifier forkChoiceNotifier = new ValidForkChoiceNotifier();
+    final ForkChoice forkChoice =
+        new ForkChoice(
+            spec,
+            eventThread,
+            recentChainData,
+            forkChoiceNotifier,
+            new ForkChoiceStateProvider(eventThread, recentChainData),
+            new TickProcessor(spec, recentChainData),
+            new AlwaysValidTransitionBlockValidator(spec, recentChainData),
+            DEFAULT_FORK_CHOICE_LATE_BLOCK_REORG_ENABLED,
+            DebugDataDumper.NOOP,
+            new StubMetricsSystem(),
+            AsyncBLSSignatureVerifier.wrap(BLSSignatureVerifier.NO_OP));
+
+    final AnchorPoint anchorPoint =
+        AnchorPoint.fromInitialBlockAndState(
+            spec, new SignedBlockAndState(anchorBlock, anchorState));
+    recentChainData.initializeFromAnchorPoint(
+        anchorPoint, spec.computeTimeAtSlot(anchorState, anchorState.getSlot()));
+
+    final PlanFetcher planFetcher = new PlanFetcher(httpClient);
+    final Map<UInt64, Optional<UInt64>> plan =
+        planFetcher.fetch(UInt64.valueOf(cfg.warmupStartSlot() + 1), UInt64.valueOf(cfg.endSlot()));
+    validatePlan(plan, cfg);
+    System.err.println(
+        "engine bootstrap done: warmup_start_slot="
+            + cfg.warmupStartSlot()
+            + " start_slot="
+            + cfg.startSlot()
+            + " end_slot="
+            + cfg.endSlot()
+            + " plan_entries="
+            + plan.size());
+
+    return new Engine(
+        cfg,
+        spec,
+        httpClient,
+        dataDir,
+        storageSystem,
+        forkChoice,
+        executionLayer,
+        plan,
+        new OutputWriter(cfg.output()));
+  }
+
+  public void run() throws IOException, InterruptedException {
+    long slotsProcessed = 0;
+    try {
+      for (long slot = cfg.warmupStartSlot() + 1; slot < cfg.endSlot(); slot++) {
+        runSlot(slot);
+        slotsProcessed++;
+      }
+    } finally {
+      System.err.println(
+          "slots_processed="
+              + slotsProcessed
+              + " records_written="
+              + outputWriter.getRecordsWritten());
+    }
+  }
+
+  @Override
+  public void close() {
+    try {
+      outputWriter.close();
+    } catch (final IOException error) {
+      System.err.println("failed to close output writer: " + error.getMessage());
+    }
+    try {
+      storageSystem.close();
+    } catch (final Exception error) {
+      System.err.println("failed to close storage system: " + error.getMessage());
+    }
+    try {
+      MoreFiles.deleteRecursively(dataDir, RecursiveDeleteOption.ALLOW_INSECURE);
+    } catch (final IOException error) {
+      System.err.println(
+          "failed to delete storage data dir " + dataDir + ": " + error.getMessage());
+    }
+  }
+
+  private void runSlot(final long simSlot) throws IOException, InterruptedException {
+    final UInt64 slot = UInt64.valueOf(simSlot);
+    final boolean isRecording = simSlot >= cfg.startSlot();
+    advanceToSlot(slot);
+    final Optional<SignedBeaconBlock> maybeBlock =
+        httpClient.getBlock(slot).map(spec::deserializeSignedBeaconBlock);
+    final boolean hasBlock = maybeBlock.isPresent();
+    final Bytes32 blockRoot = maybeBlock.map(SignedBeaconBlock::getRoot).orElse(null);
+
+    if (maybeBlock.isPresent()) {
+      final BlockImportResult result =
+          forkChoice
+              .onBlock(
+                  maybeBlock.get(), Optional.empty(), BlockBroadcastValidator.NOOP, executionLayer)
+              .join();
+      if (!result.isSuccessful()) {
+        throw new IllegalStateException(
+            "block import failed at slot " + simSlot + ": " + result.getFailureReason());
+      }
+    }
+
+    final Optional<UInt64> sourceSlot = plan.get(slot);
+    final int numInjected = injectSourceAttestations(sourceSlot);
+
+    final UInt64 evalSlot = UInt64.valueOf(simSlot + 1);
+    advanceToSlot(evalSlot);
+    final long t0 = System.nanoTime();
+    FcrForkChoiceAccess.processHead(forkChoice, evalSlot).join();
+    final long durationUs = (System.nanoTime() - t0) / 1_000;
+
+    if (simSlot % 32 == 0) {
+      printSlotDiagnostic(slot, isRecording, hasBlock);
+    }
+
+    if (isRecording) {
+      outputWriter.write(
+          buildSlotResult(slot, hasBlock, blockRoot, sourceSlot, numInjected, durationUs));
+    }
+  }
+
+  private void advanceToSlot(final UInt64 slot) {
+    forkChoice.onTick(secondsToMillis(recentChainData.computeTimeAtSlot(slot)), Optional.empty());
+  }
+
+  private void printSlotDiagnostic(
+      final UInt64 slot, final boolean isRecording, final boolean hasBlock) {
+    final Bytes32 headRoot = recentChainData.getChainHead().orElseThrow().getRoot();
+    final Bytes32 confirmedRoot = recentChainData.getStore().getConfirmedRoot();
+    final long confirmedSlot =
+        recentChainData.getSlotForBlockRoot(confirmedRoot).orElse(UInt64.ZERO).longValue();
+    System.err.println(
+        "slot="
+            + slot
+            + " is_recording="
+            + isRecording
+            + " has_block="
+            + hasBlock
+            + " head="
+            + headRoot.toHexString()
+            + " confirmed="
+            + confirmedRoot.toHexString()
+            + " confirmed_slot="
+            + confirmedSlot);
+  }
+
+  private int injectSourceAttestations(final Optional<UInt64> sourceSlot)
+      throws IOException, InterruptedException {
+    if (sourceSlot.isEmpty()) {
+      return 0;
+    }
+    final SignedBeaconBlock sourceBlock =
+        spec.deserializeSignedBeaconBlock(httpClient.getBlockRequired(sourceSlot.get()));
+    final Bytes32 headRoot = recentChainData.getChainHead().orElseThrow().getRoot();
+    final BeaconState headState = recentChainData.retrieveBlockState(headRoot).join().orElseThrow();
+    final List<ValidatableAttestation> validatableAttestations = new ArrayList<>();
+    for (Attestation attestation : sourceBlock.getMessage().getBody().getAttestations()) {
+      try {
+        final IndexedAttestation indexedAttestation =
+            spec.atSlot(sourceBlock.getSlot())
+                .getAttestationUtil()
+                .getIndexedAttestation(headState, attestation);
+        final ValidatableAttestation validatableAttestation =
+            ValidatableAttestation.from(spec, attestation);
+        validatableAttestation.setIndexedAttestation(indexedAttestation);
+        validatableAttestations.add(validatableAttestation);
+      } catch (final Throwable error) {
+        System.err.println(
+            "failed to get indexed attestation: " + error.getMessage());
+      }
+    }
+    return FcrForkChoiceAccess.applyIndexedAttestations(
+        forkChoice,
+        recentChainData,
+        validatableAttestations,
+        (attestation, error) ->
+            System.err.println(
+                "failed to apply indexed attestation: " + error.getMessage()));
+  }
+
+  private SlotResult buildSlotResult(
+      final UInt64 slot,
+      final boolean hasBlock,
+      final Bytes32 blockRoot,
+      final Optional<UInt64> sourceSlot,
+      final int numInjected,
+      final long durationUs) {
+    final Bytes32 headRoot = recentChainData.getChainHead().orElseThrow().getRoot();
+    final Bytes32 confirmedRoot = recentChainData.getStore().getConfirmedRoot();
+    final long confirmedSlot =
+        recentChainData.getSlotForBlockRoot(confirmedRoot).orElse(UInt64.ZERO).longValue();
+    final long evalSlot = slot.longValue() + 1;
+    final long delay = Math.max(0, evalSlot - confirmedSlot);
+    final boolean fastConfirmed = !confirmedRoot.isZero() && confirmedSlot == slot.longValue();
+    final boolean strictOneSlotConfirmed =
+        hasBlock
+            && !confirmedRoot.isZero()
+            && blockRoot != null
+            && blockRoot.equals(confirmedRoot)
+            && confirmedSlot == slot.longValue()
+            && delay == 1;
+
+    return new SlotResult(
+        slot.longValue(),
+        slot.longValue() / 32,
+        hasBlock,
+        blockRoot == null ? null : blockRoot.toHexString(),
+        headRoot.toHexString(),
+        confirmedRoot.toHexString(),
+        confirmedSlot,
+        delay,
+        fastConfirmed,
+        strictOneSlotConfirmed,
+        recentChainData.getStore().getFinalizedCheckpoint().getEpoch().longValue(),
+        recentChainData.getStore().getJustifiedCheckpoint().getEpoch().longValue(),
+        sourceSlot.map(UInt64::longValue).orElse(null),
+        numInjected,
+        slot.longValue() % 32 == 0,
+        !hasBlock,
+        durationUs);
+  }
+
+  private static void validatePlan(final Map<UInt64, Optional<UInt64>> plan, final Config cfg) {
+    for (long slot = cfg.warmupStartSlot() + 1; slot < cfg.endSlot(); slot++) {
+      final UInt64 key = UInt64.valueOf(slot);
+      if (!plan.containsKey(key)) {
+        throw new IllegalStateException("attestation plan missing slot " + slot);
+      }
+    }
+  }
+
+  private static class AlwaysValidTransitionBlockValidator extends MergeTransitionBlockValidator {
+    AlwaysValidTransitionBlockValidator(final Spec spec, final RecentChainData recentChainData) {
+      super(spec, recentChainData);
+    }
+
+    @Override
+    public SafeFuture<PayloadValidationResult> verifyAncestorTransitionBlock(
+        final Bytes32 chainHeadRoot) {
+      return SafeFuture.completedFuture(PayloadValidationResult.VALID);
+    }
+  }
+
+  private static class ValidForkChoiceNotifier implements ForkChoiceNotifier {
+    private final List<ForkChoiceUpdatedResultSubscriber> subscribers = new CopyOnWriteArrayList<>();
+
+    @Override
+    public void onForkChoiceUpdated(
+        final ForkChoiceState forkChoiceState, final Optional<UInt64> proposingSlot) {
+      final SafeFuture<ForkChoiceUpdatedResult> result =
+          SafeFuture.completedFuture(
+              new ForkChoiceUpdatedResult(PayloadStatus.VALID, Optional.empty()));
+      subscribers.forEach(
+          subscriber ->
+              subscriber.onForkChoiceUpdatedResult(
+                  new ForkChoiceUpdatedResultSubscriber.ForkChoiceUpdatedResultNotification(
+                      forkChoiceState, Optional.empty(), false, result)));
+    }
+
+    @Override
+    public void onAttestationsDue(final UInt64 slot) {}
+
+    @Override
+    public void onPayloadAttestationsDue(final UInt64 slot) {}
+
+    @Override
+    public void onSyncingStatusChanged(final boolean inSync) {}
+
+    @Override
+    public SafeFuture<Optional<ExecutionPayloadContext>> getPayloadId(
+        final Bytes32 parentBeaconBlockRoot, final UInt64 blockSlot) {
+      return SafeFuture.completedFuture(Optional.empty());
+    }
+
+    @Override
+    public void onTerminalBlockReached(final Bytes32 executionBlockHash) {}
+
+    @Override
+    public void subscribeToForkChoiceUpdatedResult(
+        final ForkChoiceUpdatedResultSubscriber subscriber) {
+      subscribers.add(subscriber);
+    }
+  }
+}
