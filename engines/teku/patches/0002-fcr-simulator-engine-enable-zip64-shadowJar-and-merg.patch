---
 fcr-simulator-engine/build.gradle | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/fcr-simulator-engine/build.gradle b/fcr-simulator-engine/build.gradle
index a7c3af3..61f108f 100644
--- a/fcr-simulator-engine/build.gradle
+++ b/fcr-simulator-engine/build.gradle
@@ -66,4 +66,11 @@ shadowJar {
   archiveBaseName = 'fcr-teku'
   archiveClassifier = 'all'
   archiveVersion = ''
+  zip64 = true
+  mergeServiceFiles()
+  manifest {
+    attributes(
+        'Main-Class': 'tech.pegasys.teku.statetransition.forkchoice.fcr.Main',
+        'Multi-Release': 'true')
+  }
 }
