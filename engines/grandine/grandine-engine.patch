@@ -0,0 +1,398 @@
+use std::collections::HashMap;
+use std::sync::Arc;
+use std::time::Instant;
+
+use anyhow::{Context, Result, bail};
+use crossbeam_utils::sync::WaitGroup;
+use database::Database;
+use fork_choice_control::{AdHocBenchController, MutatorHandle};
+use fork_choice_store::StoreConfig;
+use helper_functions::{accessors, misc};
+use pubkey_cache::PubkeyCache;
+use tracing::{info, warn};
+use types::{
+    combined::{BeaconState, SignedBeaconBlock},
+    config::Config as ChainConfig,
+    phase0::primitives::{H256, Slot},
+    preset::{Mainnet, Preset},
+    traits::SignedBeaconBlock as _,
+};
+
+use crate::config::{Config, Network};
+use crate::http::{AttestationPlan, BeaconFetcher, fetch_attestation_plan};
+use crate::output::{OutputWriter, SlotResult};
+
+type P = Mainnet;
+
+pub struct Engine {
+    controller: Arc<AdHocBenchController<P>>,
+    _mutator_handle: MutatorHandle<P, WaitGroup>,
+    fetcher: BeaconFetcher,
+    block_cache: HashMap<Slot, Option<Arc<SignedBeaconBlock<P>>>>,
+    plan: AttestationPlan,
+    output: OutputWriter,
+    config: EngineConfig,
+    _db_dir: tempfile::TempDir,
+}
+
+struct EngineConfig {
+    start_slot: Slot,
+    end_slot: Slot,
+    warmup_start_slot: Slot,
+}
+
+impl Engine {
+    pub async fn new(config: &Config) -> Result<Self> {
+        let chain_config = Arc::new(match config.network() {
+            Network::Mainnet => {
+                let mut c = ChainConfig::mainnet();
+                c.confirmation_byzantine_threshold = config.byzantine_threshold;
+                c
+            }
+        });
+
+        let start_slot = config.start_slot();
+        let end_slot = config.end_slot();
+        let warmup_start_slot = config.warmup_start_slot();
+
+        info!(
+            warmup_start_slot,
+            start_slot, end_slot, "Initializing Grandine FCR engine"
+        );
+
+        let fetcher = BeaconFetcher::new(config.beacon_node_url(), chain_config.clone())
+            .context("failed to create HTTP fetcher")?;
+
+        // Walk back from warmup_start_slot to the nearest epoch-start slot with a non-missed block.
+        // Grandine's Store::new requires an epoch-aligned anchor.
+        let (anchor_slot, anchor_state, anchor_block) =
+            find_epoch_aligned_anchor::<P>(&fetcher, warmup_start_slot)
+                .await
+                .context("failed to find epoch-aligned anchor")?;
+
+        info!(
+            anchor_slot,
+            warmup_start_slot,
+            catchup_slots = warmup_start_slot - anchor_slot,
+            "Selected epoch-aligned anchor",
+        );
+
+        let db_dir = tempfile::Builder::new()
+            .prefix("fcr-grandine-")
+            .rand_bytes(10)
+            .tempdir()
+            .context("failed to create temp DB dir")?;
+
+        let database = Database::in_memory();
+
+        let store_config = StoreConfig {
+            fast_confirmation_rule: true,
+            ..StoreConfig::default()
+        };
+
+        let pubkey_cache = Arc::new(PubkeyCache::default());
+        let anchor_block_arc = Arc::new(anchor_block);
+        let anchor_state_arc = Arc::new(anchor_state);
+
+        let (controller, mutator_handle) = AdHocBenchController::with_p2p_tx(
+            chain_config.clone(),
+            pubkey_cache,
+            store_config,
+            anchor_block_arc,
+            anchor_state_arc,
+            database,
+            futures::sink::drain(),
+        );
+
+        controller.on_slot(warmup_start_slot);
+        controller.wait_for_tasks();
+
+        // Catchup: import blocks from anchor_slot + 1 through warmup_start_slot.
+        info!(
+            from = anchor_slot + 1,
+            to = warmup_start_slot,
+            "Catching up anchor to warmup_start_slot"
+        );
+        let mut catchup_blocks = 0u64;
+        for slot in (anchor_slot + 1)..=warmup_start_slot {
+            if let Some(block) = fetcher
+                .fetch_block_at_slot::<P>(slot)
+                .await
+                .with_context(|| format!("failed to fetch catchup block at slot {}", slot))?
+            {
+                controller.on_replay_block(Arc::new(block));
+                controller.wait_for_tasks();
+                catchup_blocks += 1;
+            }
+        }
+        info!(catchup_blocks, "Catchup complete");
+
+        let plan = fetch_attestation_plan(
+            config.beacon_node_url(),
+            warmup_start_slot + 1,
+            end_slot,
+        )
+        .await
+        .context("failed to fetch attestation plan")?;
+        info!(plan_entries = plan.len(), "Attestation plan fetched");
+
+        for slot in (warmup_start_slot + 1)..end_slot {
+            if !plan.contains_key(&slot) {
+                bail!(
+                    "attestation plan is missing sim_slot {}; orchestrator served an incomplete plan",
+                    slot
+                );
+            }
+        }
+
+        let output =
+            OutputWriter::new(config.output()).context("failed to create JSONL output writer")?;
+
+        Ok(Self {
+            controller,
+            _mutator_handle: mutator_handle,
+            fetcher,
+            block_cache: HashMap::new(),
+            plan,
+            output,
+            config: EngineConfig {
+                start_slot,
+                end_slot,
+                warmup_start_slot,
+            },
+            _db_dir: db_dir,
+        })
+    }
+
+    pub async fn run(&mut self) -> Result<()> {
+        let mut slot = self.config.warmup_start_slot + 1;
+        let mut total_recorded = 0u64;
+        let run_start = Instant::now();
+
+        info!(
+            start_slot = slot,
+            end_slot = self.config.end_slot,
+            recording_from = self.config.start_slot,
+            "Entering simulation loop"
+        );
+
+        while slot < self.config.end_slot {
+            let is_recording = slot >= self.config.start_slot;
+            let slot_start = Instant::now();
+
+            self.controller.on_slot(slot);
+            self.controller.wait_for_tasks();
+
+            let block_at_slot = self.get_block_at_slot(slot).await?;
+            let has_block = block_at_slot.is_some();
+            let block_root = block_at_slot
+                .as_ref()
+                .map(|block| block.message().hash_tree_root());
+
+            if let Some(ref block) = block_at_slot {
+                self.controller.on_replay_block(block.clone());
+                self.controller.wait_for_tasks();
+            }
+
+            let source_slot = self.plan.get(&slot).copied().flatten();
+            let mut num_attestations_injected = 0u64;
+            if let Some(source_block_slot) = source_slot {
+                num_attestations_injected =
+                    self.inject_attestations_from_source(source_block_slot).await?;
+            }
+
+            let fcr_eval_start = Instant::now();
+            self.controller.on_slot(slot + 1);
+            self.controller.wait_for_tasks();
+            let fcr_eval_duration_us = micros_since(fcr_eval_start);
+
+            info!(
+                slot,
+                is_recording,
+                has_block,
+                num_attestations_injected,
+                fcr_eval_ms = fcr_eval_duration_us / 1000,
+                slot_ms = slot_start.elapsed().as_millis() as u64,
+                "slot done"
+            );
+
+            if is_recording {
+                let result = self.build_slot_result(
+                    slot,
+                    has_block,
+                    block_root,
+                    source_slot,
+                    num_attestations_injected,
+                    fcr_eval_duration_us,
+                );
+                total_recorded += 1;
+                self.output.write(&result)?;
+                self.output.flush_if_needed(total_recorded)?;
+            }
+
+            slot += 1;
+        }
+
+        self.output.flush()?;
+
+        info!(
+            total_slots = total_recorded,
+            duration_secs = format!("{:.1}", run_start.elapsed().as_secs_f64()),
+            "Simulation complete"
+        );
+
+        Ok(())
+    }
+
+    async fn get_block_at_slot(
+        &mut self,
+        slot: Slot,
+    ) -> Result<Option<Arc<SignedBeaconBlock<P>>>> {
+        if let Some(cached) = self.block_cache.get(&slot) {
+            return Ok(cached.clone());
+        }
+        let block = self
+            .fetcher
+            .fetch_block_at_slot::<P>(slot)
+            .await?
+            .map(Arc::new);
+        self.block_cache.insert(slot, block.clone());
+        Ok(block)
+    }
+
+    /// Replays attestations from the source block at `source_slot` using
+    /// `AttestationOrigin::Block(block_root)`. The source block need not be in the store —
+    /// `validate_attestation` only requires the attestation's target/beacon_block_root to be
+    /// present in fork-choice, not the source block itself.
+    async fn inject_attestations_from_source(&mut self, source_slot: Slot) -> Result<u64> {
+        let Some(source_block) = self.get_block_at_slot(source_slot).await? else {
+            bail!(
+                "attestation plan referenced missing source block at slot {}",
+                source_slot
+            );
+        };
+        let attestation_count = source_block.message().body().combined_attestations().count();
+        if attestation_count == 0 {
+            return Ok(0);
+        }
+
+        let block_root = source_block.message().hash_tree_root();
+        self.controller
+            .on_replay_block_attestations(block_root, source_block);
+        self.controller.wait_for_tasks();
+
+        // BlockAttestationsTask doesn't return per-attestation success counts to user space.
+        // Report the count of attestations in the source block as injected; failures are
+        // logged via mutator's warning path.
+        Ok(attestation_count as u64)
+    }
+
+    fn build_slot_result(
+        &self,
+        slot: Slot,
+        has_block: bool,
+        block_root: Option<H256>,
+        source_block_slot: Option<Slot>,
+        num_attestations_injected: u64,
+        fcr_eval_duration_us: u64,
+    ) -> SlotResult {
+        let head = self.controller.head().value;
+        let head_root = head.block_root;
+
+        let justified_epoch = self.controller.justified_checkpoint().epoch;
+        let finalized_epoch = self.controller.finalized_epoch();
+
+        let (confirmed_root, confirmed_slot) = match self.controller.confirmed_root() {
+            Some(root) if root != H256::zero() => {
+                let slot = self
+                    .controller
+                    .block_by_root(root)
+                    .ok()
+                    .flatten()
+                    .map(|with_status| with_status.value.message().slot())
+                    .unwrap_or(0);
+                (root, slot)
+            }
+            _ => (H256::zero(), 0),
+        };
+
+        let fast_confirmed = confirmed_root != H256::zero() && confirmed_slot == slot;
+        let eval_slot = slot.saturating_add(1);
+        let delay = eval_slot.saturating_sub(confirmed_slot);
+        let strict_one_slot_confirmed = has_block
+            && confirmed_root != H256::zero()
+            && block_root == Some(confirmed_root)
+            && confirmed_slot == slot
+            && delay == 1;
+
+        SlotResult {
+            slot,
+            epoch: misc::compute_epoch_at_slot::<P>(slot),
+            has_block,
+            block_root: block_root.map(format_root),
+            head_root: format_root(head_root),
+            confirmed_root: format_root(confirmed_root),
+            confirmed_slot,
+            confirmation_delay_slots: delay,
+            fast_confirmed,
+            strict_one_slot_confirmed,
+            finalized_epoch,
+            justified_epoch,
+            source_block_slot,
+            num_attestations_injected,
+            is_epoch_boundary: misc::is_epoch_start::<P>(slot),
+            is_missed_slot: !has_block,
+            fcr_eval_duration_us,
+        }
+    }
+}
+
+async fn find_epoch_aligned_anchor<P: Preset>(
+    fetcher: &BeaconFetcher,
+    warmup_start_slot: Slot,
+) -> Result<(Slot, BeaconState<P>, SignedBeaconBlock<P>)> {
+    let initial_epoch = misc::compute_epoch_at_slot::<P>(warmup_start_slot);
+    for epoch in (0..=initial_epoch).rev() {
+        let epoch_slot = misc::compute_start_slot_at_epoch::<P>(epoch);
+        match fetcher.fetch_block_at_slot::<P>(epoch_slot).await {
+            Ok(Some(block)) => {
+                let state = fetcher
+                    .fetch_state_at_slot::<P>(epoch_slot)
+                    .await
+                    .with_context(|| {
+                        format!("failed to fetch state at anchor slot {}", epoch_slot)
+                    })?;
+                // Sanity: state.latest_block_root must equal block.hash_tree_root.
+                let latest = accessors::latest_block_root(&state);
+                let block_root = block.message().hash_tree_root();
+                if latest != block_root {
+                    warn!(
+                        epoch_slot,
+                        latest = ?latest,
+                        block_root = ?block_root,
+                        "anchor state's latest_block_root != block.root; skipping",
+                    );
+                    continue;
+                }
+                return Ok((epoch_slot, state, block));
+            }
+            Ok(None) => continue,
+            Err(e) => {
+                warn!(epoch_slot, error = ?e, "failed to fetch candidate anchor block; trying earlier epoch");
+                continue;
+            }
+        }
+    }
+    bail!(
+        "no epoch-aligned non-missed slot found at or before warmup_start_slot {}",
+        warmup_start_slot
+    )
+}
+
+fn format_root(root: H256) -> String {
+    format!("0x{}", hex::encode(root))
+}
+
+fn micros_since(start: Instant) -> u64 {
+    start.elapsed().as_micros().min(u128::from(u64::MAX)) as u64
+}
