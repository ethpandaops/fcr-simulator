# Copy to .env and fill in. .env is gitignored.

# Beacon node with archive-mode states enabled.
# Lighthouse: must be run with --reconstruct-historic-states
# Teku:       must be run with --data-storage-mode=ARCHIVE
# Recent ranges (within ~256 epochs of head) may work without archive mode.
BN_URL=https://user:pass@your-beacon-node.example.com:5052

# Path to the engine binary (default: ./results/fcr-lighthouse).
# Set this if your engine binary is elsewhere.
# FCR_ENGINE_BINARY=/usr/local/bin/fcr-lighthouse
